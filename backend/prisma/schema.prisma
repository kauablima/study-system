generator client {
  provider = "prisma-client"
  output   = "../src/database"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  subjects         Subject[]
  weekly_schedules Weekly_schedule[]
  study_sessions   Study_session[]
  revisions        Revision[]
}

model Subject {
  id        String   @id @default(uuid())
  name      String
  color     String
  createdAt DateTime @default(now())
  user_id   String
  user      User     @relation(fields: [user_id], references: [id])

  study_sessions Study_session[]
}

model Weekly_schedule {
  id          String @id @default(uuid())
  day_of_week Int

  user    User   @relation(fields: [user_id], references: [id])
  user_id String
}

model Study_session {
  id                String   @id @default(uuid())
  topic             String
  durantion_minutes Int
  study_date        DateTime

  user_id    String
  user       User    @relation(fields: [user_id], references: [id])
  subject_id String
  subject    Subject @relation(fields: [subject_id], references: [id])

  revisions Revision[]
}

model Revision {
  id      String   @id @default(uuid())
  status  String   @default("PENDING")
  dueDate DateTime

  user_id String
  user    User   @relation(fields: [user_id], references: [id])

  study_id String
  study    Study_session @relation(fields: [study_id], references: [id])
}
